# ─── Vercel Frontend Environment Variables ────────────────────────────────────
# Copy this to .env.local for local development.
# On Vercel: add these in Project → Settings → Environment Variables

# REQUIRED — your Render API URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://nishon-ai-api.onrender.com

# Optional — used by some public pages (landing pages, portfolio)
# Same value as NEXT_PUBLIC_API_BASE_URL
NEXT_PUBLIC_API_URL=https://nishon-ai-api.onrender.com

# ─── Meta Ads Integration ────────────────────────────────────────────────────

# PostgreSQL connection string (Prisma) — can be the same DB as the API
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Meta App credentials (from Meta for Developers → My Apps)
META_APP_ID=
META_APP_SECRET=

# Base URL of this Next.js app (used for OAuth redirect_uri)
NEXT_PUBLIC_APP_URL=https://adspectr.com

# AES-256-GCM key for encrypting stored tokens
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=
