{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@performa/ai-sdk$": "<rootDir>/../packages/ai-sdk/src/index.ts",
    "^@performa/shared$": "<rootDir>/../packages/shared/src/index.ts"
  },
  "collectCoverageFrom": [
    "src/**/*.{js,ts}",
    "!src/**/*.spec.ts",
    "!src/**/*.entity.ts",
    "!src/**/index.ts"
  ],
  "coverageDirectory": "../coverage/e2e",
  "testTimeout": 30000
}
