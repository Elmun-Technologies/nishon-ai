# Meta
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_GRAPH_VERSION=v19.0
META_RETARGET_ADSET_ID=

# Infra
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@localhost:5432/adspectr

# Redis stream key for signal-bridge events (real-time bus)
REDIS_EVENTS_STREAM=retargeting:events
REDIS_EVENTS_GROUP=retargeting-worker
REDIS_EVENTS_CONSUMER=worker-1

# Legacy list keys pattern: events:{signal_bridge_id} — JSON lines
REDIS_LEGACY_EVENTS_PREFIX=events:

# Targets (account currency major units, e.g. UZS as shown in Ads Manager)
TARGET_CPA=20000
TARGET_ROAS=4
MIN_AUDIENCE_SIZE=1000

# Frequency cap (requires AdImpression / delivery events with signal_bridge_id)
FREQUENCY_CAP_PER_DAY=2

# Optional dry run (no Meta writes)
DRY_RUN=false

# CPA > target: decrease_budget (5-blok) yoki pause_adset (prompt 3)
CPA_STRATEGY=decrease_budget
