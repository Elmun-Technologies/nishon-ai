{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@adspectr/shared": [
                "packages/shared/src"
            ],
            "@adspectr/ai-sdk": [
                "packages/ai-sdk/src"
            ]
        }
    },
    "include": [
        "packages/**/*",
        "apps/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}