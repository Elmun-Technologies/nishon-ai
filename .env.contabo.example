# ── Nishon AI — self-host env template (Contabo / any VPS) ───────────────────
# Copy to `.env` next to docker-compose.contabo.yml and fill in. Never commit .env.

# Your domain (the web app runs at https://<DOMAIN>, the API at https://api.<DOMAIN>)
DOMAIN=example.com
# Email for Let's Encrypt registration / expiry notices
ACME_EMAIL=you@example.com

# ── Database (created inside the postgres container) ─────────────────────────
POSTGRES_DB=nishon
POSTGRES_USER=nishon
POSTGRES_PASSWORD=change-me-strong-password

# ── Auth secrets ─────────────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
# openssl rand -hex 16  (must be EXACTLY 32 characters)
ENCRYPTION_KEY=

# ── AI provider (required for strategy / chat / focus group / chat-launch) ───
# Use "openai" with OPENAI_API_KEY, or "anthropic" with ANTHROPIC_API_KEY.
AI_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Meta advertising (core MVP) ──────────────────────────────────────────────
# developers.facebook.com → your app. Register this exact OAuth redirect URI:
#   https://api.<DOMAIN>/meta/callback
META_APP_ID=
META_APP_SECRET=

# ── Optional activations (leave blank → feature reports "not configured") ────
FAL_KEY=
TGSTAT_API_KEY=
HEYGEN_API_KEY=
HIGGSFIELD_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Payme billing (webhook URL: https://api.<DOMAIN>/billing/payme)
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
PAYME_TEST_MODE=

# ── Google Sign-In (optional; blank → the Google button is hidden) ───────────
# Register this exact redirect URI in Google Cloud Console:
#   https://api.<DOMAIN>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
