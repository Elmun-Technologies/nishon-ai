NODE_ENV=production
PORT=3001

# ─── Public URLs ──────────────────────────────────────────────────────────────
API_BASE_URL=https://performa-ai-api.onrender.com
FRONTEND_URL=https://performa-ai.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://performa-ai-api.onrender.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Use DATABASE_URL (Render, Railway, Supabase) or individual fields below
# Set TYPEORM_SYNCHRONIZE=true once after adding new columns, then remove it
TYPEORM_SYNCHRONIZE=false
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# REQUIRED — must be exactly 32 characters for AES-256 token encryption
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# ─── AI Provider (Production) ────────────────────────────────────────────────
# Select LLM vendor: openai | anthropic | meta
# "meta" = Meta Llama hosted API (OpenAI-compatible chat). Separate from Meta Ads OAuth below.
AI_PROVIDER=openai

# OpenAI (official)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional override (Azure/OpenAI gateway). Leave empty for official:
# https://api.openai.com/v1
OPENAI_BASE_URL=

# Anthropic Claude (official)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Optional override. Leave empty for official:
# https://api.anthropic.com/v1
ANTHROPIC_BASE_URL=

# Meta Llama API — only when AI_PROVIDER=meta
# Docs: https://llama.developer.meta.com/ — use the OpenAI-compatible base URL from your console.
META_AI_API_KEY=
META_AI_BASE_URL=
# Optional: one model id for all tasks (overrides per-task Llama routing in @adspectr/ai-sdk)
# META_AI_MODEL=Llama-3.3-70B-Instruct

# ─── Meta (Facebook / Instagram) Ads ─────────────────────────────────────────
# Get from: https://developers.facebook.com/apps
# Required scopes: ads_management, ads_read, business_management
META_APP_ID=
META_APP_SECRET=
# Must exactly match the "Valid OAuth Redirect URIs" in your Meta App Dashboard
# Format: https://<your-api-domain>/platforms/meta/callback
META_CALLBACK_URL=https://performa-ai-api.onrender.com/platforms/meta/callback

# ─── Google Ads ───────────────────────────────────────────────────────────────
# OAuth credentials from: https://console.cloud.google.com
# Enable "Google Ads API" in the API library
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# REQUIRED for Google Sign-In (social login) — must exactly match
# "Authorized redirect URIs" in your Google Cloud Console OAuth app
# Format: https://<your-api-domain>/auth/google/callback
GOOGLE_CALLBACK_URL=https://performa-ai-api.onrender.com/auth/google/callback
# Developer token from: https://ads.google.com/home/tools/manager-accounts
# Required for all Google Ads API calls
GOOGLE_DEVELOPER_TOKEN=

# ─── TikTok Ads ───────────────────────────────────────────────────────────────
# Create an app at: https://ads.tiktok.com/marketing_api/apps
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ─── Yandex Direct ───────────────────────────────────────────────────────────
# Create an app at: https://oauth.yandex.ru
# Required scopes: direct
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ─── Telegram Notifications (optional) ───────────────────────────────────────
# Create a bot at: https://t.me/BotFather
# Used for daily performance reports sent to workspace owners
TELEGRAM_BOT_TOKEN=
# Admin chat ID for marketplace contact notifications
TELEGRAM_ADMIN_CHAT_ID=

# ─── Demo / Seed Data ─────────────────────────────────────────────────────────
# Password for the demo user created by seed scripts (dev/staging only)
# Generate with: openssl rand -base64 16
DEMO_USER_PASSWORD=

# ─── Content Generation ───────────────────────────────────────────────────────
# Higgsfield AI — video generation for ad creatives
HIGGSFIELD_API_KEY=
# HeyGen — AI photo avatars (Creative Hub → AI Actors). Server-side only; do not expose to the browser.
HEYGEN_API_KEY=

# ─── Payment (Payme) ─────────────────────────────────────────────────────────
# Payme Merchant API credentials — get from merchant.paycom.uz
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
PAYME_MERCHANT_TEST_KEY=
# Set to "true" to use Payme test environment (test.paycom.uz)
PAYME_TEST_MODE=true

# ─── Ads Intelligence ─────────────────────────────────────────────────────────
# Manus — Facebook ads research and intelligence
MANUS_API_KEY=
