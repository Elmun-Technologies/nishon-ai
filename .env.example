NODE_ENV=production
PORT=3001

# Public URLs
API_BASE_URL=https://nishon-ai.onrender.com
FRONTEND_URL=https://nishon-ai-web.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://nishon-ai.onrender.com

# Database
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=

# Redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379

# Traffic protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=

# AI
OPENAI_API_KEY=

# Meta OAuth
META_APP_ID=
META_APP_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# TikTok OAuth
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Optional integrations
TELEGRAM_BOT_TOKEN=
