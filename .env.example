NODE_ENV=production
PORT=3001

# Public URLs
API_BASE_URL=https://nishon-ai.onrender.com
FRONTEND_URL=https://nishon-ai-web.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://nishon-ai.onrender.com

# Database
# Set TYPEORM_SYNCHRONIZE=true once to sync schema after adding new columns, then remove it
TYPEORM_SYNCHRONIZE=false
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=

# Redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379

# Traffic protection
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=

# AI (Agent Router — https://api.agentrouter.org)
AGENT_ROUTER_API_KEY=
AGENT_ROUTER_BASE_URL=https://api.agentrouter.org

# Meta OAuth
# META_CALLBACK_URL must match the "Valid OAuth Redirect URIs" in your Meta App Dashboard exactly.
# Format: https://<your-backend-domain>/meta/callback
META_APP_ID=
META_APP_SECRET=
META_CALLBACK_URL=https://nishon-ai.onrender.com/meta/callback

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=

# TikTok OAuth
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Optional integrations
TELEGRAM_BOT_TOKEN=
